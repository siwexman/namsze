{
    "expo": {
        "name": "namsze",
        "slug": "namsze",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "light",
        "newArchEnabled": true,
        "splash": {
            "image": "./assets/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
        },
        "ios": {
            "supportsTablet": true
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#ffffff"
            },
            "edgeToEdgeEnabled": true
        },
        "web": {
            "favicon": "./assets/favicon.png"
        },
        "plugins": [
            [
                "expo-image-picker",
                {
                    "photosPermission": "Aplikacja korzysta z kamery celem zrobienia zdjęcia kościołom.",
                    "colors": {
                        "cropToolbarColor": "#000000"
                    },
                    "dark": {
                        "colors": {
                            "cropToolbarColor": "#000000"
                        }
                    }
                }
            ]
        ]
    }
}
